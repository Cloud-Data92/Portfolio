# PolyBot configuration — copy to .env and fill in.
#
# SECURITY: keep real credentials in ~/.config/polybot/.env (chmod 600), NOT in the
# project directory. The project .env is for non-sensitive overrides only —
# src/config.py loads the secure file first and never lets this file override it.

# ── Polymarket credentials (SECURE FILE ONLY) ─────────────────────
POLYMARKET_PRIVATE_KEY=0xyour_polygon_wallet_private_key
POLYMARKET_API_KEY=your_clob_api_key
POLYMARKET_API_SECRET=your_clob_api_secret
POLYMARKET_API_PASSPHRASE=your_clob_api_passphrase
POLYMARKET_SIGNATURE_TYPE=0
POLYMARKET_FUNDER=
POLYMARKET_PROXY_ADDRESS=
POLYMARKET_HOST=https://clob.polymarket.com

# ── Trading settings ──────────────────────────────────────────────
DRY_RUN=true
TARGET_PAIR_COST=0.97
ORDER_SIZE=5
MIN_TIME_REMAINING=120
SCAN_INTERVAL=1
BTC_PRICE_SOURCE=binance

# Optional: reference wallet to mirror as a confirmation signal
SIGNAL_WALLET=

# ── Alerts (optional) ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# ── Dashboard ─────────────────────────────────────────────────────
DASHBOARD_ENABLED=true
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080

# ── History / logging ─────────────────────────────────────────────
ALERT_HISTORY_ENABLED=true
LOG_LEVEL=INFO

# ── AI advisor sidecar (optional — advisory only, cannot trade) ───
NVIDIA_API_KEY=your_nvidia_nim_api_key
OPENAI_API_KEY=your_openai_compatible_api_key
ADVISOR_DRY_RUN=true
